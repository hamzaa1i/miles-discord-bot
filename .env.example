# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Owner Discord user ID (used for /owner commands and AI personality)
OWNER_ID=123456789012345678

# GitHub Models API token (used for AI features — same backend as cogs/ai_chat.py)
GITHUB_TOKEN=your_github_token_here

# Optional: OpenRouter API Key (legacy, if using paid AI features)
OPENROUTER_API_KEY=your_api_key_here
